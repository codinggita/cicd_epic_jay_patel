    {
      "name": "Authentication",
      "description": "User account registration, logins, session lists, password resetting, and Multi-Factor Authentication (2FA) controls.",
      "item": [
        {
          "name": "Register New User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Regular DevOps Engineer\",\n  \"email\": \"user@devops.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register standard user credentials with email checking and strong password rules."
          }
        },
        {
          "name": "User Login (Standard)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseData = pm.response.json();",
                  "if (responseData.success && responseData.data.token) {",
                  "    pm.environment.set(\"token\", responseData.data.token);",
                  "    pm.environment.set(\"userId\", responseData.data.user.id || responseData.data.user._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@devops.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticate user, returning signed JWT and automatically saving token to Environment Variables."
          }
        },
        {
          "name": "User Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseData = pm.response.json();",
                  "if (responseData.success && responseData.data.token) {",
                  "    pm.environment.set(\"adminToken\", responseData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@devops.com\",\n  \"password\": \"AdminPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticate admin, returning signed JWT and saving it to adminToken."
          }
